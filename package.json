{
  "name": "aura-alpha-desktop",
  "version": "8.0.0",
  "description": "Aura Alpha — Autonomous Trading Intelligence Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "cc.auraalpha.desktop",
    "productName": "Aura Alpha",
    "directories": { "output": "release" },
    "files": ["main.js", "preload.js", "worker.js", "updater.js", "dist/**/*", "assets/**/*"],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "artifactName": "AuraAlpha_${version}_aarch64.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "artifactName": "AuraAlpha_${version}_amd64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "AuraAlpha_${version}_x64-setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "sgallup23",
      "repo": "AuraAlphaDesktop"
    }
  }
}
