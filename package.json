{
  "name": "aura-alpha-desktop",
  "version": "9.1.0",
  "description": "Aura Alpha \u2014 Autonomous Trading Intelligence Platform",
  "author": {
    "name": "Aura Holdings LLC",
    "email": "shawn@auraalpha.cc"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "cc.auraalpha.desktop",
    "productName": "Aura Alpha",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "worker.js",
      "updater.js",
      "dist/**/*",
      "assets/**/*",
      "grid_worker/**/*",
      "!grid_worker/venv/**/*",
      "!grid_worker/__pycache__/**/*",
      "!grid_worker/**/__pycache__/**/*"
    ],
    "extraResources": [
      {
        "from": "grid_worker",
        "to": "grid_worker",
        "filter": [
          "**/*",
          "!venv/**/*",
          "!**/__pycache__/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "artifactName": "AuraAlpha_${version}_${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "artifactName": "AuraAlpha_${version}_amd64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "AuraAlpha_${version}_x64-setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "sgallup23",
      "repo": "AuraAlphaDesktop"
    }
  }
}